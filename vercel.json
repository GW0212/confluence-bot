{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/favicon/(.*)", "destination": "/public/favicon/$1" },
    { "source": "/((?!favicon/).*)", "destination": "/public/index.html" }
  ],
  "functions": {
    "api/ask.js": { "maxDuration": 60 },
    "api/pages.js": { "maxDuration": 60 },
    "api/page-content.js": { "maxDuration": 30 },
    "api/find-page.js": { "maxDuration": 30 },
    "api/recent-pages.js": { "maxDuration": 30 },
    "api/changed-pages.js": { "maxDuration": 30 },
    "api/attachment.js": { "maxDuration": 30 }
  }
}
